{
  "cli": {
    "version": ">= 12.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "ios": {
        "autoIncrement": true
      },
      "android": {
        "autoIncrement": true
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "FILL_IN_APPLE_ID",
        "ascAppId": "FILL_IN_ASC_APP_ID",
        "appleTeamId": "FILL_IN_TEAM_ID"
      }
    }
  }
}
